{
  "name": "depmender",
  "version": "2.3.4",
  "description": "Comprehensive CLI tool for dependency management - unified 'depmender fix' command handles all operations: scan, fix, install-missing, remove-unused, update-deps, dedupe, sync, resolve, and more. Supports npm, yarn, pnpm with security audits and real-time monitoring.",
  "main": "dist/index.js",
  "bin": {
    "depmender": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "build:prod": "tsc --declaration false --declarationMap false --sourceMap false",
    "dev": "tsc --watch",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,json,md}\"",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean && npm run typecheck",
    "pretest": "npm run typecheck",
    "prepare": "npm run build:prod",
    "prepublishOnly": "npm run test && npm run build:prod"
  },
  "keywords": [
    "dependency",
    "dependencies",
    "npm",
    "yarn",
    "pnpm",
    "package-manager",
    "dependency-management",
    "dependency-checker",
    "dependency-analyzer",
    "dependency-scanner",
    "security",
    "security-audit",
    "vulnerability",
    "vulnerability-scanner",
    "outdated",
    "outdated-packages",
    "audit",
    "npm-audit",
    "cli",
    "cli-tool",
    "command-line",
    "devtools",
    "developer-tools",
    "nodejs",
    "node",
    "javascript",
    "typescript",
    "package-json",
    "lockfile",
    "node-modules",
    "dependency-health",
    "dependency-fix",
    "auto-fix",
    "dependency-cleanup",
    "unused-dependencies",
    "dependency-monitor",
    "watch-mode",
    "real-time-monitoring",
    "project-health",
    "code-quality",
    "maintenance",
    "automation",
    "ci-cd",
    "continuous-integration",
    "build-tools",
    "package-maintenance",
    "npm tool",
    "dependency manager",
    "repair",
    "package"
  ],
  "author": "Raj Khajanchi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/r2708/depmender.git"
  },
  "bugs": {
    "url": "https://github.com/r2708/depmender/issues"
  },
  "homepage": "https://github.com/r2708/depmender#readme",
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^11.1.0",
    "fs-extra": "^11.3.3",
    "node-fetch": "^3.3.2",
    "ora": "^5.4.1",
    "semver": "^7.7.4",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.19.35",
    "@types/node-fetch": "^2.6.13",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.39.2",
    "prettier": "^3.3.3",
    "typescript": "^5.9.3",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ]
}
